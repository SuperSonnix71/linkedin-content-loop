# AI provider (OpenAI SDK compatible)
AI_BASE_URL=http://localhost:11434/v1
AI_API_KEY=ollama
AI_MODEL=llama3.2

# LinkedIn credentials (browser automation)
LINKEDIN_EMAIL=you@example.com
LINKEDIN_PASSWORD=your-password

# PostgreSQL database (auto-creates DB + tables on first run)
DB_HOST=192.168.1.234
DB_PORT=5432
DB_USER=sonny
DB_PASSWORD=postgres
# Subject selection: "volume" (most views) or "insight" (most surprising)
SUBJECT_SELECTION=insight
