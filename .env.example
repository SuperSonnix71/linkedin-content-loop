# ============================================================
# LinkedIn Content Loop — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit secrets.
# ============================================================

# --- AI Model (OpenAI SDK compatible) ---
# Any OpenAI-compatible endpoint works.
# Ollama:      http://localhost:11434/v1
# LM Studio:   http://localhost:1234/v1
# Groq:        https://api.groq.com/openai/v1
# OpenRouter:  https://openrouter.ai/api/v1
AI_BASE_URL=http://localhost:11434/v1

# API key for the model provider.
# Ollama accepts any non-empty string (e.g. "ollama").
# Groq/OpenRouter require a real API key.
AI_API_KEY=ollama

# Model name — must be available on your server.
# Check available models: curl http://your-server/v1/models
AI_MODEL=llama3.2

# --- LinkedIn Credentials ---
# The browser automation uses these to log in.
# Session is saved to browser-profile/ so login only happens once.
# If 2FA is enabled, complete it manually on first run with headless=False.
LINKEDIN_EMAIL=you@example.com
LINKEDIN_PASSWORD=your-password

# --- PostgreSQL Database ---
# The pipeline auto-creates the database and tables on first run.
# Just provide a user that has CREATEDB privileges.
DB_HOST=192.168.1.234
DB_PORT=5432
DB_USER=sonny
DB_PASSWORD=postgres
DB_NAME=linkedin_loop

# --- Subject Selection (optional) ---
# How the pipeline picks which subject to write about.
# Leave commented to auto-balance between the two modes.
# volume  = pick the subject with the most YouTube views / Reddit activity
# insight = pick the subject with the most surprising / counter-intuitive finding
# When commented out, the pipeline checks the DB and alternates to keep a 50/50 mix.
# SUBJECT_SELECTION=insight
